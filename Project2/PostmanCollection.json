{
  "info": {
    "name": "Project 2 - User Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/",
          "host": ["localhost"],
          "port": "3000",
          "path": [""]
        }
      }
    },
    {
      "name": "Get All Users",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/users",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users"]
        }
      }
    },
    {
      "name": "Get User By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/users/1",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users", "1"]
        }
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Charlie Brown\",\n  \"email\": \"charlie@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/users",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users"]
        }
      }
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Charlie Updated\",\n  \"email\": \"charlie.updated@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/users/3",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users", "3"]
        }
      }
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:3000/users/3",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users", "3"]
        }
      }
    }
  ]
}
